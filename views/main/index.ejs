
<% layout('layout/boilerplate.ejs') -%>
<div class="container-fluid container index" style="height: 68vh;">
  
    <div class="row forms" >
      <!-- <div class="col container col-4">
        <h1>FJS Enterprenous</h1>
        <h3>Unlock Your Team's Potential!" "Harmonize Your Employee Experience</h3>
      </div> -->
      <div class="col form1 col-4 offset-3">
        <h1 class="text-center" >Mark your attendance</h1>
        <!-- Check-In Form -->
<form id="checkInForm" action="/checkin" method="POST">
  <input type="text" id="employeeName" name="name" placeholder="Employee Name" required>
  <input type="hidden" id="latitudeIn" name="latitude">
  <input type="hidden" id="longitudeIn" name="longitude">
  <input type="hidden" id="cityIn" name="city">
  <input type="hidden" id="intime" name="intime">
  <input type="hidden" id="dateIn" name="date">
  <button type="submit" id="checkInBtn">Check In</button>
</form>

<!-- Check-Out Form -->
<form id="checkOutForm" action="/checkout" method="POST">
  <input type="text" id="employeeNameOut" name="name" placeholder="Employee Name" required>
  <input type="hidden" id="latitudeOut" name="latitude">
  <input type="hidden" id="longitudeOut" name="longitude">
  <input type="hidden" id="cityOut" name="city">
  <input type="hidden" id="outtime" name="outtime">
  <input type="hidden" id="dateOut" name="date">
  <button type="submit" id="checkOutBtn">Check Out</button>
</form>
      </div>
      <div class="col container form1 col-4" >
        <form method="post" action="/verify"  novalidate class="needs-validation">
          <h1 class="text-center">Admin</h1>
          <label for="" class="form-label">Admin Name</label>
          <input type="text" placeholder="Enter Admin" name="username" class="form-control" required>
          <div class="invalid-feedback">
            Please provide a Valid Admin Name
          </div>
          <label for="" class="form-label">Password</label>
          <input type="text" placeholder="Enter your Password" name="password" class="form-control" required>
          <div class="invalid-feedback">
            Please provide a Valid Password
          </div>
          <button type="submit" class="btn btn-outline-success mt-4 mb-4">Login</button>
        </form>
      </div>
    </div>
</div>
<script src="/js/geolocation.js"></script>